<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
  <id>Kaz.Operations</id>
  <version>1.0.12</version> <authors>Bronsk1y</authors>
  <description>Библиотека для выполнения операций над текстом, числами и коллекциями.</description>
  <license type="expression">MIT</license>
  
  <icon>images\OperationsIcon.png</icon>
  <readme>docs\README.md</readme>
  
  <dependencies>
    <group targetFramework="net472">
      <dependency id="Kaz.Operations.Core" version="1.0.12" />
    </group>
  </dependencies>
</metadata>

<files>
  <file src="bin\Release\Kaz.Operations.dll" target="lib\net472" />
  <file src="bin\Release\Kaz.Operations.xml" target="lib\net472" />
  
  <file src="OperationsIcon.png" target="images\" />
  
  <file src="README.md" target="docs\" />
</files>
</package>